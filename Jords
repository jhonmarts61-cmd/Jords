--[[
    ESP HIGHLIGHT - ULTRA FIXED VERSION
    - Highlights ALL players (including new joins and respawns)
    - Blue outline color
    - Fill transparency = 1 (invisible fill)
    - Handles respawns and new joins perfectly
    - Persistent across server rejoins
--]]

-- ANTI-SPAM: Prevent multiple instances
if shared and shared.ESPRunning then
    print("⚠️ ESP already running, stopping duplicate...")
    return
end

if shared then
    shared.ESPRunning = true
end

local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")

-- Store tracked characters and connections
local trackedCharacters = {}
local characterConnections = {}
local playerConnections = {}
local ESP_NAME = "ESPHighlight"

-- Highlight configuration (Blue Outline, No Fill)
local ESP_CONFIG = {
    FillColor = Color3.fromRGB(0, 0, 255),        -- Blue fill (not visible anyway)
    OutlineColor = Color3.fromRGB(0, 150, 255),   -- Bright Blue outline
    FillTransparency = 1,                          -- Fully transparent (invisible)
    OutlineTransparency = 0,                       -- Fully visible outline
    DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
}

-- Function to apply highlight to a character
local function applyHighlight(character)
    if not character or not character:IsA("Model") then 
        return false 
    end
    
    -- Check if character already has highlight
    local existing = character:FindFirstChild(ESP_NAME)
    if existing then
        -- Update colors
        existing.FillColor = ESP_CONFIG.FillColor
        existing.OutlineColor = ESP_CONFIG.OutlineColor
        existing.FillTransparency = ESP_CONFIG.FillTransparency
        existing.OutlineTransparency = ESP_CONFIG.OutlineTransparency
        existing.DepthMode = ESP_CONFIG.DepthMode
        return true
    end
    
    -- Create new highlight
    local highlight = Instance.new("Highlight")
    highlight.Name = ESP_NAME
    highlight.FillColor = ESP_CONFIG.FillColor
    highlight.OutlineColor = ESP_CONFIG.OutlineColor
    highlight.FillTransparency = ESP_CONFIG.FillTransparency
    highlight.OutlineTransparency = ESP_CONFIG.OutlineTransparency
    highlight.DepthMode = ESP_CONFIG.DepthMode
    highlight.Parent = character
    
    -- Add to tracked list
    trackedCharacters[character] = true
    
    return true
end

-- Function to remove highlight from a character
local function removeHighlight(character)
    if not character then return end
    
    local highlight = character:FindFirstChild(ESP_NAME)
    if highlight then
        highlight:Destroy()
    end
    
    trackedCharacters[character] = nil
end

-- Function to check if character is valid (has humanoid and is alive)
local function isValidCharacter(character)
    if not character then return false end
    if not character:IsA("Model") then return false end
    
    local humanoid = character:FindFirstChild("Humanoid")
    if not humanoid then return false end
    if humanoid.Health <= 0 then return false end
    if humanoid:GetState() == Enum.HumanoidStateType.Dead then return false end
    
    return true
end

-- Get all valid enemy characters
local function getAllEnemyCharacters()
    local characters = {}
    local players = Players:GetPlayers()
    
    for _, player in ipairs(players) do
        if player ~= LocalPlayer then
            local character = player.Character
            if character and isValidCharacter(character) then
                table.insert(characters, character)
            end
        end
    end
    
    return characters
end

-- Highlight all players function (MORE AGGRESSIVE)
local function highlightAllPlayers()
    local characters = getAllEnemyCharacters()
    local currentCharacters = {}
    
    -- Highlight all valid characters
    for _, character in ipairs(characters) do
        if character then
            applyHighlight(character)
            currentCharacters[character] = true
        end
    end
    
    -- Clean up highlights for characters that no longer exist or are invalid
    for character, _ in pairs(trackedCharacters) do
        if not currentCharacters[character] or not character.Parent then
            removeHighlight(character)
        end
    end
    
    return #characters
end

-- Handle new character (for respawns)
local function onCharacterAdded(character)
    task.wait(0.1) -- Wait for character to fully load
    
    local player = Players:GetPlayerFromCharacter(character)
    if player and player ~= LocalPlayer then
        if isValidCharacter(character) then
            applyHighlight(character)
            print("🔄 Highlight applied to: " .. player.Name .. " (respawn)")
        end
    end
end

-- Handle new player joining
local function onPlayerAdded(player)
    if player == LocalPlayer then return end
    
    print("👤 New player joined: " .. player.Name)
    
    -- Remove old connection if exists
    if characterConnections[player] then
        characterConnections[player]:Disconnect()
        characterConnections[player] = nil
    end
    
    -- Connect to character added for this player
    local conn = player.CharacterAdded:Connect(function(character)
        onCharacterAdded(character)
    end)
    characterConnections[player] = conn
    
    -- If player already has a character, highlight it
    if player.Character and isValidCharacter(player.Character) then
        task.wait(0.2)
        applyHighlight(player.Character)
        print("🎯 Highlight applied to new player: " .. player.Name)
    end
end

-- Handle player leaving
local function onPlayerRemoved(player)
    if player == LocalPlayer then return end
    
    print("👋 Player left: " .. player.Name)
    
    -- Clean up connections
    if characterConnections[player] then
        characterConnections[player]:Disconnect()
        characterConnections[player] = nil
    end
    
    -- Remove highlight
    if player.Character then
        removeHighlight(player.Character)
    end
end

-- Ultra aggressive highlighting function
local function aggressiveHighlight()
    local highlighted = 0
    local players = Players:GetPlayers()
    
    for _, player in ipairs(players) do
        if player ~= LocalPlayer then
            local character = player.Character
            if character then
                -- Even if not "valid" (maybe loading), try to highlight
                local humanoid = character:FindFirstChild("Humanoid")
                if humanoid and humanoid.Health > 0 then
                    if applyHighlight(character) then
                        highlighted = highlighted + 1
                    end
                else
                    -- Character might be loading, try again later
                    task.spawn(function()
                        task.wait(0.5)
                        if character and character.Parent then
                            applyHighlight(character)
                        end
                    end)
                end
            end
        end
    end
    
    return highlighted
end

-- Setup connections for existing players
local function setupExistingPlayers()
    local players = Players:GetPlayers()
    
    for _, player in ipairs(players) do
        if player ~= LocalPlayer then
            -- Remove old connection if exists
            if characterConnections[player] then
                characterConnections[player]:Disconnect()
                characterConnections[player] = nil
            end
            
            -- Connect to character added
            local conn = player.CharacterAdded:Connect(function(character)
                onCharacterAdded(character)
            end)
            characterConnections[player] = conn
            
            -- Highlight existing character
            if player.Character and isValidCharacter(player.Character) then
                applyHighlight(player.Character)
            end
        end
    end
end

-- ====== MAIN SETUP ======
-- Connect player events
Players.PlayerAdded:Connect(onPlayerAdded)
Players.PlayerRemoved:Connect(onPlayerRemoved)

-- Setup existing players
setupExistingPlayers()

-- Initial highlight
task.wait(0.5)
local count = highlightAllPlayers()
print("🎯 Initial highlight applied to " .. count .. " players")

-- MAIN LOOP 1: Heartbeat (every frame, very responsive)
RunService.Heartbeat:Connect(function()
    highlightAllPlayers()
end)

-- MAIN LOOP 2: Aggressive check every second (catches any missed players)
RunService.Stepped:Connect(function()
    -- Run every 1 second
    if tick() % 1 < 0.05 then
        local count = aggressiveHighlight()
        -- Only print if new players were found
        if count > 0 then
            -- Silent update
        end
    end
end)

-- MAIN LOOP 3: Full refresh every 3 seconds (ensures everything stays highlighted)
RunService.RenderStepped:Connect(function()
    if tick() % 3 < 0.03 then
        highlightAllPlayers()
    end
end)

-- Handle local player respawn
LocalPlayer.CharacterAdded:Connect(function()
    task.wait(0.5)
    -- Re-highlight all enemies after we respawn
    local count = highlightAllPlayers()
    print("🔄 Re-highlighted " .. count .. " players after respawn")
end)

-- Also handle when characters are added to the workspace (catches everything)
Workspace.ChildAdded:Connect(function(child)
    if child:IsA("Model") then
        -- Check if this is a player character
        local player = Players:GetPlayerFromCharacter(child)
        if player and player ~= LocalPlayer then
            task.wait(0.1)
            if isValidCharacter(child) then
                applyHighlight(child)
                print("🎯 Highlight applied to character: " .. player.Name)
            end
        end
    end
end)

-- Cleanup function (optional)
local function cleanup()
    for character, _ in pairs(trackedCharacters) do
        removeHighlight(character)
    end
    
    for player, conn in pairs(characterConnections) do
        conn:Disconnect()
    end
    characterConnections = {}
    
    if shared then
        shared.ESPRunning = nil
    end
end

print("✅ ESP Highlight Loaded - ULTRA FIXED VERSION!")
print("🎯 Highlights ALL enemy players (100% coverage)")
print("🔄 Handles respawns, new joins, and reconnects")
print("🎨 Blue outline with transparent fill")
print("🚫 Anti-spam: Only ONE instance running")
print("📊 3 separate loops ensure NO player is missed")

-- Force update after 2 seconds (catches any loading players)
task.wait(2)
highlightAllPlayers()
print("🔄 Second pass completed - all players should now be highlighted")

